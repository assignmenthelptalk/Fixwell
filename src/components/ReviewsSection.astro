---
const reviews = [
  {
    name: 'Frances Ryan',
    badge: 'Local Guide',
    date: '8 months ago',
    rating: 5,
    text: 'After trying for months to get a handyman, we are very happy to have found FixWell. We had a long list of small jobs that had built up over the months and they have all been completed within two weeks at times that were convenient to us. FixWell were professional and reliable with a focus on customer satisfaction.',
  },
  {
    name: 'Harvey Mills',
    badge: 'Local Guide',
    date: '2 weeks ago',
    rating: 5,
    text: 'As a landlord with a property in Salisbury, it\'s always stress-free working with FixWell Services. They recently handled a turn-over maintenance checklist for me between tenants, fixing fixtures, repairing some minor damage, and checking appliances. Always punctual, tidy, and highly professional. Five stars.',
  },
  {
    name: 'Andrew Griffin',
    badge: 'Local Guide',
    date: '2 weeks ago',
    rating: 5,
    text: 'It\'s hard to find a dependable handyman who covers the villages outside Salisbury, so I\'m glad I found FixWell. They handled a list of small property repairs for me, were fully insured, and charged a very reasonable rate. Professional and friendly throughout.',
  },
];
---
<section class="reviews section" aria-labelledby="reviews-heading">
  <div class="container">
    <div class="section-header">
      <span class="tag">Google Reviews</span>
      <h2 id="reviews-heading">Trusted by Homeowners & Landlords</h2>
      <p>Fully insured, professional, and reliable. Here is what our customers say.</p>
    </div>
    <div class="reviews-grid">
      {reviews.map((r) => (
        <article class="card review-card">
          <div class="review-header">
            <div class="review-stars" aria-label={`${r.rating} out of 5 stars`}>
              {'★'.repeat(r.rating)}
            </div>
            <img src="https://www.google.com/images/branding/googlelogo/2x/googlelogo_color_92x30dp.png" alt="Google" class="google-logo" width="46" height="15" loading="lazy" />
          </div>
          <blockquote>
            <p>"{r.text}"</p>
          </blockquote>
          <footer class="review-footer">
            <strong>{r.name}</strong>
            <span>{r.badge} · {r.date}</span>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
<style>
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .review-card { display: flex; flex-direction: column; gap: 1rem; }
  .review-header { display: flex; align-items: center; justify-content: space-between; }
  .review-stars { color: #f59e0b; font-size: 1.1rem; letter-spacing: .05em; }
  .google-logo { height: 15px; width: auto; object-fit: contain; opacity: .75; }
  blockquote p { color: var(--text-muted); font-size: .95rem; line-height: 1.7; font-style: italic; }
  .review-footer { display: flex; flex-direction: column; gap: .15rem; margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border); }
  .review-footer strong { color: var(--navy); font-size: .9rem; }
  .review-footer span { color: var(--text-light); font-size: .8rem; }
</style>
