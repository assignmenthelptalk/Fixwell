---
import { site } from '../data/site';
import { mainNav } from '../data/navigation';
---

<header class="header">
  <div class="top-bar">
    <div class="container top-bar__inner">
      <span>Fully Insured &bull; Salisbury &amp; Wiltshire</span>
      <a href={`tel:${site.phone}`} class="top-bar__phone">
        📞 {site.phoneDisplay}
      </a>
    </div>
  </div>

  <nav class="nav" aria-label="Main navigation">
    <div class="container nav__inner">
      <a href="/" class="nav__logo" aria-label={site.name}>
        <span class="logo-icon">FW</span>
        <span class="logo-text">
          <strong>FixWell</strong>
          <small>Services</small>
        </span>
      </a>

      <ul class="nav__links" id="nav-menu" role="list">
        {mainNav.map((item) => (
          <li class={item.children ? 'has-dropdown' : ''}>
            <a href={item.href}>{item.label}</a>
            {item.children && (
              <ul class="dropdown" role="list">
                {item.children.map((child) => (
                  <li><a href={child.href}>{child.label}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>

      <a href="/contact" class="btn btn--primary nav__cta">Get a Quote</a>

      <button
        class="nav__toggle"
        id="nav-toggle"
        aria-controls="nav-menu"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
</header>

<style>
  .header { position: sticky; top: 0; z-index: 100; background: white; box-shadow: 0 2px 8px rgba(0,0,0,.08); }

  .top-bar {
    background: var(--navy);
    color: rgba(255,255,255,.85);
    font-size: .8rem;
    padding: .4rem 0;
  }
  .top-bar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .top-bar__phone {
    color: white;
    font-weight: 600;
    letter-spacing: .02em;
  }
  .top-bar__phone:hover { color: var(--orange-light); }

  .nav { padding: .75rem 0; }
  .nav__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: .625rem;
    flex-shrink: 0;
    text-decoration: none;
  }
  .logo-icon {
    width: 40px;
    height: 40px;
    background: var(--navy);
    color: var(--orange);
    border-radius: 8px;
    display: grid;
    place-items: center;
    font-weight: 800;
    font-size: .9rem;
    letter-spacing: -.02em;
    flex-shrink: 0;
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .logo-text strong { font-size: 1.05rem; color: var(--navy); }
  .logo-text small { font-size: .75rem; color: var(--text-muted); font-weight: 400; }

  .nav__links {
    display: flex;
    list-style: none;
    gap: .25rem;
    flex: 1;
    justify-content: center;
    margin: 0;
  }

  .nav__links > li {
    position: relative;
  }

  .nav__links > li > a {
    display: block;
    padding: .5rem .75rem;
    font-size: .9rem;
    font-weight: 500;
    color: var(--text);
    border-radius: var(--radius);
    transition: color .15s, background .15s;
    white-space: nowrap;
  }
  .nav__links > li > a:hover { color: var(--navy); background: var(--bg-light); }

  .has-dropdown:hover .dropdown { opacity: 1; visibility: visible; transform: translateY(0); }

  .dropdown {
    position: absolute;
    top: calc(100% + .5rem);
    left: 0;
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    list-style: none;
    min-width: 240px;
    padding: .5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all .2s;
    z-index: 200;
  }
  .dropdown li a {
    display: block;
    padding: .5rem .75rem;
    font-size: .875rem;
    color: var(--text-muted);
    border-radius: 6px;
    transition: all .15s;
    white-space: nowrap;
  }
  .dropdown li a:hover { color: var(--navy); background: var(--bg-light); }

  .nav__cta { flex-shrink: 0; white-space: nowrap; }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: .5rem;
    margin-left: auto;
    border-radius: 6px;
  }
  .nav__toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--navy);
    border-radius: 2px;
    transition: all .3s;
  }
  .nav__toggle:hover { background: var(--bg-light); }

  @media (max-width: 900px) {
    .nav__cta { display: none; }
    .nav__toggle { display: flex; }

    .nav__links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: white;
      border-top: 1px solid var(--border);
      box-shadow: var(--shadow-lg);
      flex-direction: column;
      gap: 0;
      padding: .75rem;
      justify-content: flex-start;
      z-index: 150;
    }
    .nav__links.open { display: flex; }

    .nav__links > li > a { padding: .75rem 1rem; font-size: 1rem; }

    .has-dropdown .dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      border: none;
      border-left: 3px solid var(--border);
      border-radius: 0;
      margin-left: 1rem;
      padding: .25rem 0;
    }
  }
</style>
