---
const GOOGLE_REVIEW_URL = 'https://maps.app.goo.gl/3N1zMwDTx9e3s8VZ9?g_st=ic';

// TODO before launch: Update overallRating and reviewCount to match real Google listing values.
// TODO before launch: Replace these sample reviews with real Google reviews (copy text from
//   Google Maps) or remove and rely solely on the "Read reviews on Google" link.
// ⚠️  These are SAMPLE / PLACEHOLDER reviews for design purposes only.
const overallRating = '4.9';
const reviewCount = 47;

const reviews = [
  {
    name: 'Sarah M.',
    rating: 5,
    text: 'Absolutely brilliant service. Called in the morning about a burst pipe and FixWell were with me by lunchtime. Professional, tidy, and fixed it first time.',
    date: 'December 2024',
  },
  {
    name: 'David T.',
    rating: 5,
    text: 'Reliable, prompt and reasonably priced. I use FixWell for all my rental properties in the Salisbury area. Always does a quality job and never lets me down.',
    date: 'November 2024',
  },
  {
    name: 'Claire R.',
    rating: 5,
    text: 'Had several odd jobs done — shelves fitted, a broken door sorted, and skirting boards painted. Excellent standard throughout. Very friendly and professional.',
    date: 'October 2024',
  },
];
---

<section class="google-reviews section section--light" aria-labelledby="google-reviews-heading">
  <div class="container">
    <div class="section-header">
      <span class="tag">Google Reviews</span>
      <div class="gr-overall" role="img" aria-label={`Rated ${overallRating} out of 5 on Google, based on ${reviewCount} reviews`}>
        <span class="gr-overall__score">{overallRating}</span>
        <div class="gr-overall__stars" aria-hidden="true">★★★★★</div>
        <span class="gr-overall__count">Based on {reviewCount} Google reviews</span>
        <svg class="gr-google-logo" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
      </div>
      <h2 id="google-reviews-heading">What Our Customers Say</h2>
      <p>Trusted by homeowners and landlords across Salisbury and Wiltshire.</p>
    </div>

    <div class="grid-3">
      {reviews.map((r) => (
        <article class="card gr-card">
          <header class="gr-card__header">
            <div class="gr-card__avatar" aria-hidden="true">
              {r.name.charAt(0)}
            </div>
            <div class="gr-card__meta">
              <strong class="gr-card__name">{r.name}</strong>
              <span class="gr-card__date">{r.date}</span>
            </div>
            <svg class="gr-card__logo" viewBox="0 0 24 24" width="18" height="18" aria-label="Google review" role="img">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </header>

          <div class="gr-card__stars" aria-label={`${r.rating} out of 5 stars`}>
            {'★'.repeat(r.rating)}
          </div>

          <blockquote>
            <p>"{r.text}"</p>
          </blockquote>
        </article>
      ))}
    </div>

    <div class="gr-cta">
      <a
        href={GOOGLE_REVIEW_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--outline"
        aria-label="Read all FixWell Services reviews on Google (opens in new tab)"
      >
        Read all reviews on Google →
      </a>
    </div>
  </div>
</section>

<style>
  .gr-overall {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .625rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .gr-overall__score {
    font-size: 2rem;
    font-weight: 800;
    color: var(--navy);
    line-height: 1;
  }

  .gr-overall__stars {
    color: #f59e0b;
    font-size: 1.25rem;
    letter-spacing: .05em;
    line-height: 1;
  }

  .gr-overall__count {
    font-size: .875rem;
    color: var(--text-muted);
  }

  .gr-google-logo {
    display: block;
    flex-shrink: 0;
  }

  .gr-card {
    display: flex;
    flex-direction: column;
    gap: .875rem;
  }

  .gr-card__header {
    display: flex;
    align-items: center;
    gap: .625rem;
  }

  .gr-card__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--navy);
    color: white;
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: .9rem;
    flex-shrink: 0;
  }

  .gr-card__meta {
    display: flex;
    flex-direction: column;
    gap: .1rem;
    flex: 1;
  }

  .gr-card__name {
    font-size: .875rem;
    color: var(--navy);
    font-weight: 700;
    line-height: 1.2;
  }

  .gr-card__date {
    font-size: .75rem;
    color: var(--text-light);
  }

  .gr-card__logo {
    margin-left: auto;
    flex-shrink: 0;
  }

  .gr-card__stars {
    color: #f59e0b;
    font-size: 1rem;
    letter-spacing: .04em;
  }

  .gr-card blockquote p {
    color: var(--text-muted);
    font-size: .9rem;
    line-height: 1.7;
    font-style: italic;
  }

  .gr-cta {
    text-align: center;
    margin-top: 2.5rem;
  }
</style>
