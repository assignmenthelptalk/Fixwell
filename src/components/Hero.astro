---
import { site } from '../data/site';

interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  ctaPrimary?: { text: string; href: string };
  ctaSecondary?: { text: string; href: string };
  variant?: 'homepage' | 'service' | 'location' | 'article';
}

const {
  title,
  subtitle,
  badge,
  ctaPrimary = { text: 'Get a Free Quote', href: '/contact' },
  ctaSecondary,
  variant = 'service',
} = Astro.props;
---

<section class={`hero hero--${variant}`} aria-labelledby="hero-title">
  <div class="container hero__inner">
    <div class="hero__content">
      {badge && <span class="hero__badge">{badge}</span>}
      <h1 id="hero-title">{title}</h1>
      {subtitle && <p class="hero__subtitle">{subtitle}</p>}
      <div class="hero__actions">
        <a href={ctaPrimary.href} class="btn btn--primary btn--lg">{ctaPrimary.text}</a>
        {ctaSecondary && (
          <a href={ctaSecondary.href} class="btn btn--outline btn--lg">{ctaSecondary.text}</a>
        )}
        <a href={`tel:${site.phone}`} class="hero__phone-cta">
          <span class="phone-icon">📞</span>
          <span>
            <small>Call direct</small>
            <strong>{site.phoneDisplay}</strong>
          </span>
        </a>
      </div>
    </div>
    {variant === 'homepage' && (
      <div class="hero__aside">
        <div class="hero__card">
          <div class="hero__card-header">
            <span class="emergency-dot"></span>
            <strong>Available Today</strong>
          </div>
          <p>Same-day emergency callouts across Salisbury & Wiltshire</p>
          <a href="/emergency-handyman-salisbury" class="btn btn--white" style="margin-top:.75rem;">
            Emergency Callout →
          </a>
        </div>
        <div class="hero__stats">
          <div class="stat">
            <strong>Fully</strong>
            <span>Insured</span>
          </div>
          <div class="stat">
            <strong>£20–40</strong>
            <span>per hour</span>
          </div>
          <div class="stat">
            <strong>Mon–Sun</strong>
            <span>7am–8pm</span>
          </div>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
    color: white;
    padding: 3.5rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }

  .hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
  }

  .hero--service .hero__inner,
  .hero--location .hero__inner,
  .hero--article .hero__inner {
    grid-template-columns: 1fr;
    max-width: 800px;
  }

  .hero--homepage { padding: 4rem 0; }
  .hero--service { padding: 3rem 0; }

  .hero__badge {
    display: inline-block;
    background: rgba(212, 101, 12, .25);
    border: 1px solid rgba(212, 101, 12, .4);
    color: #fbbf71;
    font-size: .8rem;
    font-weight: 600;
    padding: .3rem .875rem;
    border-radius: 100px;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: .06em;
  }

  .hero h1 { color: white; margin-bottom: 1rem; font-size: clamp(1.75rem, 4.5vw, 2.75rem); }

  .hero__subtitle {
    color: rgba(255,255,255,.8);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 560px;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__phone-cta {
    display: flex;
    align-items: center;
    gap: .625rem;
    color: rgba(255,255,255,.9);
    transition: color .15s;
  }
  .hero__phone-cta:hover { color: white; }
  .phone-icon { font-size: 1.25rem; }
  .hero__phone-cta span { display: flex; flex-direction: column; line-height: 1.2; }
  .hero__phone-cta small { font-size: .7rem; color: rgba(255,255,255,.6); }
  .hero__phone-cta strong { font-size: 1rem; font-weight: 700; }

  /* Homepage aside */
  .hero__aside { display: flex; flex-direction: column; gap: 1rem; min-width: 240px; }

  .hero__card {
    background: rgba(255,255,255,.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }
  .hero__card-header {
    display: flex;
    align-items: center;
    gap: .5rem;
    margin-bottom: .5rem;
  }
  .hero__card-header strong { color: white; font-size: .95rem; }
  .emergency-dot {
    width: 8px;
    height: 8px;
    background: #4ade80;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(74,222,128,.4); }
    50% { opacity: .8; box-shadow: 0 0 0 6px rgba(74,222,128,0); }
  }
  .hero__card p { color: rgba(255,255,255,.7); font-size: .9rem; }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .5rem;
  }
  .stat {
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: var(--radius);
    padding: .75rem .5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }
  .stat strong { color: white; font-size: 1rem; line-height: 1; }
  .stat span { color: rgba(255,255,255,.6); font-size: .7rem; }

  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__aside { display: none; }
  }
</style>
