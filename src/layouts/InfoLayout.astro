---
import BaseLayout from './BaseLayout.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  h1: string;
  slug: string;
  faqs?: { q: string; a: string }[];
}

const { title, description, h1, slug, faqs = [] } = Astro.props;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: h1, href: `/${slug}` },
];

const wordCount = 800;
const readTime = Math.ceil(wordCount / 200);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: h1,
  description,
  url: `${site.url}/${slug}`,
  author: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
  publisher: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
  datePublished: '2026-06-17',
  dateModified: new Date().toISOString().split('T')[0],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: b.label,
    item: b.href.startsWith('http') ? b.href : `${site.url}${b.href}`,
  })),
};

const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const schemas = [articleSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];
---

<BaseLayout
  title={title}
  description={description}
  schema={schemas}
>
  <BreadcrumbNav crumbs={breadcrumbs} />
  <div class="article-meta">
    <div class="container">
      <span class="tag">Advice</span>
      <span class="read-time">{readTime} min read</span>
    </div>
  </div>
  <slot />
</BaseLayout>

<style>
  .article-meta {
    background: var(--bg-light);
    padding: .75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .article-meta .container {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .read-time {
    font-size: .875rem;
    color: var(--text-light);
  }
</style>
